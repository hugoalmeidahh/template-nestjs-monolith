{
  "name": "template-api-monolith",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "prisma:generate": "npx prisma generate && npx prisma generate --schema=./prisma-user/schema.prisma --config=./prisma-user/prisma.config.ts",
    "prisma:migrate-deploy": "npx prisma migrate deploy",
    "prisma:create-migration": "npx prisma migrate dev --create-only --name",
    "prisma:migrate-dev": "npx prisma migrate dev",
    "docker:build": "docker build -t template-api-monolith . && docker container rm template-api-monolith && docker container create --name template-api-monolith -p 3777:3777 template-api-monolith",
    "docker:start": "docker start template-api-monolith",
    "docker:stop": "docker stop template-api-monolith",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest  --runInBand --config ./test/jest-e2e.json",
    "e2e-infra:up": "node -r ts-node/register -r tsconfig-paths/register ./test/e2e-runtime/infra-up.ts",
    "e2e-infra:reset": "node -r ts-node/register -r tsconfig-paths/register ./test/e2e-runtime/infra-reset.ts",
    "e2e-infra:show": "node -r ts-node/register -r tsconfig-paths/register ./test/e2e-runtime/infra-show.ts",
    "e2e:start": "jest --runInBand --config ./test/jest-e2e-reuse.json",
    "e2e-infra:down": "node -r ts-node/register -r tsconfig-paths/register ./test/e2e-runtime/infra-down.ts",
    "ai-update": "npm update @hugops/ai-prompts"
  },
  "dependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/big.js": "^6.2.2",
    "@types/express": "^5.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/passport-http": "^0.3.11",
    "@types/request-ip": "^0.0.41",
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/client-secrets-manager": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/swagger": "^11.0.3",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sentry/nestjs": "^9.1.0",
    "@sentry/profiling-node": "^9.1.0",
    "@smithy/types": "^4.12.0",
    "amqplib": "^0.10.5",
    "big.js": "^7.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "joi": "^17.13.3",
    "js-convert-case": "^4.2.0",
    "luxon": "^3.6.1",
    "nestjs-pino": "^4.3.0",
    "newrelic": "^13.12.0",
    "passport": "^0.7.0",
    "passport-http": "^0.3.0",
    "password-validator": "^5.3.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.3.0",
    "prisma-pagination": "^0.2.3",
    "reflect-metadata": "^0.2.2",
    "request-ip": "^3.3.0",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^9.8.0",
    "@nestjs/testing": "^11.0.1",
    "@hugops/ai-prompts": "github:hugopsinc/ai-prompts",
    "@testcontainers/postgresql": "^10.18.0",
    "@testcontainers/rabbitmq": "^10.18.0",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!@internal/prisma|@internal/prisma-user)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}